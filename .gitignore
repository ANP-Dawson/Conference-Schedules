# module.sig IS committed: it's regenerated by `tools/sign-module.php` on the
# maintainer's machine after any module-file change, then committed alongside
# the change. Anyone cloning gets a verified sig because tools/signing-key.pub
# is auto-imported by install.php.

# IMPORTANT: do NOT ignore vendor/ — FreePBX modules ship vendor in-tree.
# IMPORTANT: do NOT ignore composer.lock — pin runtime deps for reproducible installs.
